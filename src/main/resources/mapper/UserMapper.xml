<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.infinite.prism.moss.mapper.UserMapper">

    <select id="selectByEmail" parameterType="java.lang.String" resultType="com.infinite.prism.moss.entity.DO.UserDO">
        SELECT * FROM user WHERE email = #{email} AND deleted = 0
    </select>

</mapper>